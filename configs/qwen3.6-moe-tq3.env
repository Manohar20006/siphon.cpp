# Default local server configuration for Qwen3.6 MoE.

MODEL=models/Qwen3.6-35B-A3B-UD-Q4_K_M.gguf
EXPERTS=expert-suites/moe-static-experts-suite-8192.txt
ALIAS=qwen3.6-moe-tq3
HOST=127.0.0.1
PORT=8090

CTX=65536
export LLAMA_DSTORAGE_PREFILL_WORKSPACE=0
export LLAMA_DSTORAGE_PREFILL_WORKSPACE_LOOKAHEAD=2
BATCH=512
UBATCH=128

MOE_GPU_CACHE_MIB=2816
MOE_PINNED_CACHE_MIB=4096
CACHE_RAM_MIB=2048
GDS_READ_THREADS=20

# The 1536 MiB pinned cache budget alone is enough to keep peak RAM safe.
# Do NOT set LLAMA_MOE_PINNED_PREFILL_ONLY=1 here: that flag frees the pinned
# expert cache after every prefill, which kills decode speed (drops from
# ~18-20 tok/s down to ~10-11 tok/s) because every decode step then has to
# reload hot experts from NVMe instead of hitting the warm pinned cache.

SPEC_DRAFT_N_MAX=3
SPEC_DRAFT_P_MIN=0
SPEC_TYPE=draft-mtp

# Create chat prompt checkpoints at every useful turn boundary. The upstream
# default is 256 tokens, which can leave short agent/chat turns reprocessing
# from the system prompt instead of reusing the growing conversation prefix.
CHECKPOINT_MIN_STEP=0

# Limit checkpoints per slot to 12 (default is 32) to prevent excessive memory usage
# at large context sizes (each checkpoint takes ~80-180 MiB of CPU RAM).
export LLAMA_ARG_CTX_CHECKPOINTS=12

# Leave empty to use the model's embedded Qwen chat template. Plain ChatML can
# reduce prompt-template differences, but this model may then emit visible
# <think> tags, so it is best kept as an opt-in experiment:
# CHAT_TEMPLATE=chatml
CHAT_TEMPLATE=

# Crucial for reasoning models: prevents the llama.cpp chat template from stripping
# or hiding the model's intermediate <think> reasoning process. This ensures reasoning
# tokens are preserved in the context history across multi-turn exchanges.
CHAT_TEMPLATE_KWARGS='{"preserve_thinking": true}'
REASONING=off
REASONING_FORMAT=deepseek
REASONING_BUDGET=0

# KV-shift cache reuse is disabled by default because the current MTP
# speculative context reports it unsupported. Prompt cache/checkpoints remain on.
CACHE_REUSE=0

# Expose /metrics for cache and latency checks.
METRICS=1
